{
  "name": "background",
  "displayName": "background",
  "description": "Bring background images to your vscode",
  "version": "2.0.10",
  "packageManager": "pnpm@11.2.2",
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "26.2.0",
      "onFail": "error"
    },
    "packageManager": {
      "name": "pnpm",
      "version": "11.2.2",
      "onFail": "error"
    }
  },
  "scripts": {
    "vscode:uninstall": "node ./dist/uninstall.js",
    "typecheck": "tsc --noEmit -p ./",
    "bundle": "node ./esbuild.js",
    "bundle:prod": "node ./esbuild.js --production",
    "compile": "pnpm run typecheck && pnpm run bundle",
    "watch": "npm-run-all -p watch:typecheck watch:bundle",
    "watch:bundle": "node ./esbuild.js --watch",
    "watch:typecheck": "tsc --noEmit --watch -p ./",
    "lint": "eslint src",
    "package": "pnpm run typecheck && pnpm run bundle:prod && node ./scripts/package-vsix.cjs",
    "prepare": "husky"
  },
  "publisher": "shalldie",
  "author": "shalldie",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/shalldie/vscode-background.git"
  },
  "engines": {
    "vscode": "^1.94.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "extensionKind": [
    "ui",
    "workspace"
  ],
  "main": "./dist/extension.js",
  "l10n": "./l10n",
  "contributes": {
    "commands": [
      {
        "command": "extension.background.info",
        "category": "Background",
        "title": "%extension.background.command.info.title%"
      },
      {
        "command": "extension.background.install",
        "category": "Background",
        "title": "%extension.background.command.install.title%"
      },
      {
        "command": "extension.background.disable",
        "category": "Background",
        "title": "%extension.background.command.disable.title%"
      },
      {
        "command": "extension.background.uninstall",
        "category": "Background",
        "title": "%extension.background.command.uninstall.title%"
      },
      {
        "command": "extension.background.previewPatch",
        "category": "Background",
        "title": "[Dev] Preview Patch"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "background",
      "properties": {
        "background.enabled": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "%extension.background.enabled.description%"
        },
        "background.useFront": {
          "type": "boolean",
          "default": true,
          "markdownDeprecationMessage": "%extension.background.common.deprecation%"
        },
        "background.style": {
          "type": "object",
          "default": {
            "background-position": "100% 100%",
            "background-size": "auto",
            "opacity": 0.6
          },
          "markdownDeprecationMessage": "%extension.background.common.deprecation%"
        },
        "background.styles": {
          "type": "array",
          "default": [
            {},
            {},
            {}
          ],
          "markdownDeprecationMessage": "%extension.background.common.deprecation%"
        },
        "background.customImages": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "markdownDeprecationMessage": "%extension.background.common.deprecation%"
        },
        "background.interval": {
          "type": "number",
          "default": 0,
          "markdownDeprecationMessage": "%extension.background.common.deprecation%"
        },
        "background.editor": {
          "type": "object",
          "default": {
            "useFront": true,
            "style": {
              "background-position": "100% 100%",
              "background-size": "auto",
              "opacity": 0.6
            },
            "styles": [
              {},
              {},
              {}
            ],
            "images": [],
            "interval": 0,
            "random": false
          },
          "properties": {
            "useFront": {
              "type": "boolean",
              "default": true,
              "markdownDescription": "%extension.background.editor.useFront%"
            },
            "style": {
              "type": "object",
              "default": {
                "background-position": "100% 100%",
                "background-size": "auto",
                "opacity": 0.6
              },
              "markdownDescription": "%extension.background.editor.style%"
            },
            "styles": {
              "type": "array",
              "default": [
                {},
                {},
                {}
              ],
              "markdownDescription": "%extension.background.editor.styles%"
            },
            "images": {
              "type": "array",
              "default": [],
              "items": {
                "type": "string"
              },
              "markdownDescription": "%extension.background.editor.images%"
            },
            "interval": {
              "type": "number",
              "default": 0,
              "markdownDescription": "%extension.background.editor.interval%"
            },
            "random": {
              "type": "boolean",
              "default": false,
              "markdownDescription": "%extension.background.editor.random%"
            }
          },
          "markdownDescription": "%extension.background.editor.description%"
        },
        "background.fullscreen": {
          "type": "object",
          "default": {
            "images": [],
            "opacity": 0.1,
            "size": "cover",
            "position": "center",
            "interval": 0,
            "random": false
          },
          "properties": {
            "images": {
              "type": "array",
              "default": [],
              "items": {
                "type": "string"
              },
              "markdownDescription": "%extension.background.editor.images%"
            },
            "opacity": {
              "type": "number",
              "default": 0.1,
              "minimum": 0,
              "maximum": 0.6,
              "markdownDescription": "%extension.background.fullscreen.opacity%"
            },
            "size": {
              "type": "string",
              "default": "cover",
              "markdownDescription": "%extension.background.fullscreen.size%"
            },
            "position": {
              "type": "string",
              "default": "center",
              "markdownDescription": "%extension.background.fullscreen.position%"
            },
            "interval": {
              "type": "number",
              "default": 0,
              "markdownDescription": "%extension.background.fullscreen.interval%"
            },
            "random": {
              "type": "boolean",
              "default": false,
              "markdownDescription": "%extension.background.fullscreen.random%"
            }
          },
          "markdownDescription": "%extension.background.fullscreen.description%"
        },
        "background.sidebar": {
          "type": "object",
          "default": {
            "images": [],
            "opacity": 0.1,
            "size": "cover",
            "position": "center",
            "interval": 0,
            "random": false
          },
          "properties": {
            "images": {
              "$ref": "#/properties/background.fullscreen/properties/images"
            },
            "opacity": {
              "$ref": "#/properties/background.fullscreen/properties/opacity"
            },
            "size": {
              "$ref": "#/properties/background.fullscreen/properties/size"
            },
            "position": {
              "$ref": "#/properties/background.fullscreen/properties/position"
            },
            "interval": {
              "$ref": "#/properties/background.fullscreen/properties/interval"
            },
            "random": {
              "$ref": "#/properties/background.fullscreen/properties/random"
            }
          },
          "markdownDescription": "%extension.background.sidebar.description%"
        },
        "background.auxiliarybar": {
          "type": "object",
          "default": {
            "images": [],
            "opacity": 0.1,
            "size": "cover",
            "position": "center",
            "interval": 0,
            "random": false
          },
          "properties": {
            "images": {
              "$ref": "#/properties/background.fullscreen/properties/images"
            },
            "opacity": {
              "$ref": "#/properties/background.fullscreen/properties/opacity"
            },
            "size": {
              "$ref": "#/properties/background.fullscreen/properties/size"
            },
            "position": {
              "$ref": "#/properties/background.fullscreen/properties/position"
            },
            "interval": {
              "$ref": "#/properties/background.fullscreen/properties/interval"
            },
            "random": {
              "$ref": "#/properties/background.fullscreen/properties/random"
            }
          },
          "markdownDescription": "%extension.background.auxiliarybar.description%"
        },
        "background.panel": {
          "type": "object",
          "default": {
            "images": [],
            "opacity": 0.1,
            "size": "cover",
            "position": "center",
            "interval": 0,
            "random": false
          },
          "properties": {
            "images": {
              "$ref": "#/properties/background.fullscreen/properties/images"
            },
            "opacity": {
              "$ref": "#/properties/background.fullscreen/properties/opacity"
            },
            "size": {
              "$ref": "#/properties/background.fullscreen/properties/size"
            },
            "position": {
              "$ref": "#/properties/background.fullscreen/properties/position"
            },
            "interval": {
              "$ref": "#/properties/background.fullscreen/properties/interval"
            },
            "random": {
              "$ref": "#/properties/background.fullscreen/properties/random"
            }
          },
          "markdownDescription": "%extension.background.panel.description%"
        }
      }
    }
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "catalog:",
    "@secretlint/secretlint-formatter-sarif": "catalog:",
    "@secretlint/secretlint-rule-basicauth": "catalog:",
    "@secretlint/secretlint-rule-no-dotenv": "catalog:",
    "@secretlint/secretlint-rule-npm": "catalog:",
    "@secretlint/secretlint-rule-preset-recommend": "catalog:",
    "@secretlint/secretlint-rule-privatekey": "catalog:",
    "@types/node": "catalog:",
    "@types/stylis": "catalog:",
    "@types/vscode": "catalog:",
    "@typescript-eslint/eslint-plugin": "catalog:",
    "@typescript-eslint/parser": "catalog:",
    "@vscode/vsce": "catalog:",
    "esbuild": "catalog:",
    "eslint": "catalog:",
    "eslint-config-prettier": "catalog:",
    "eslint-plugin-prettier": "catalog:",
    "husky": "catalog:",
    "npm-run-all": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:"
  },
  "dependencies": {
    "@vscode/sudo-prompt": "catalog:",
    "fast-glob": "catalog:",
    "stylis": "catalog:"
  }
}
